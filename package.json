{
  "name": "placement-cell",
  "version": "1.0.0",
  "description": "Placement Cell Management System",
  "scripts": {
    "start": "concurrently \"npm start --prefix backend\" \"PORT=3001 npm start --prefix frontend\"",
    "start:backend": "npm start --prefix backend",
    "start:frontend": "PORT=3001 npm start --prefix frontend",
    "db:setup": "npm run db:setup --prefix backend",
    "db:import:edpeee": "npm run db:import:edpeee --prefix backend",
    "db:import:edpeee:dry-run": "npm run db:import:edpeee:dry-run --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
